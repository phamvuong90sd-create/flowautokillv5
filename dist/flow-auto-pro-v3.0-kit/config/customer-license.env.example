# Copy this file to customer-license.env and fill values before shipping to customer
# If set, installer will auto-configure online license without asking these fields.

# Required for offline activation (author-rsa)
PRESET_AUTHOR_CODE=

# Required online license config for installer (new flow)
PRESET_LICENSE_API_BASE=https://your-app.vercel.app/api/license
PRESET_LICENSE_KEY=LIC-XXXX-XXXX-XXXX
